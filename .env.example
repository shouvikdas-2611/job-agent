# ============================================
# Job Agent — Environment Configuration
# Rename this file to ".env" and fill in values
# ============================================

# --- Turso Database (REQUIRED for Render deployment — free, no card) ---
# Get free DB at: https://turso.tech
#   1. Sign up → Create database → name it "jobagent"
#   2. turso db show jobagent --url   → paste as TURSO_DB_URL
#   3. turso db tokens create jobagent → paste as TURSO_AUTH_TOKEN
# Leave blank for local dev (uses local SQLite file automatically)
TURSO_DB_URL=libsql://jobagent-yourname.turso.io
TURSO_AUTH_TOKEN=eyJh...your-token

# --- Google Gemini API (REQUIRED — FREE) ---
# Get your free key in 2 minutes (no credit card needed):
#   1. Go to https://aistudio.google.com
#   2. Click "Get API Key" → "Create API key"
#   3. Paste it below
# Free tier: 15 requests/min, 1M tokens/day — more than enough
GEMINI_API_KEY=AIza-your-key-here

# --- Job Search API (REQUIRED — FREE tier available) ---
# JSearch via RapidAPI — aggregates Indeed, LinkedIn, Glassdoor, ZipRecruiter
# Sign up free at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 150 requests/month (enough for ~5 users weekly)
RAPIDAPI_KEY=your-rapidapi-key-here

# --- Adzuna (OPTIONAL — free 250 calls/month) ---
# Extra job source for India industry roles
# Sign up at: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Email (REQUIRED) ---
# Brevo HTTP API is REQUIRED for Render (Render blocks ALL outbound SMTP ports).
# Sign up free at brevo.com (300 emails/day free, no card).
# Get the key: Brevo dashboard → SMTP & API → **API Keys** tab → Generate a new API key
# IMPORTANT: This must be a v3 API KEY (not the SMTP key). It does NOT start with xsmtpib.
BREVO_API_KEY=xkeysib-your-v3-api-key-here

# Gmail — used as the FROM address (and for local dev SMTP fallback only)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM_NAME=Job Agent

# --- Server ---
PORT=3000
NODE_ENV=development
